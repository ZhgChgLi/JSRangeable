{
  "name": "rangeable-js",
  "version": "1.0.0",
  "description": "Hashable-element interval set with first-insert ordered active queries.",
  "keywords": [
    "interval",
    "range",
    "merge",
    "boundary-events",
    "rfc",
    "typescript"
  ],
  "license": "MIT",
  "author": "ZhgChgLi <zhgchgli@gmail.com>",
  "homepage": "https://github.com/ZhgChgLi/JSRangeable",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZhgChgLi/JSRangeable.git"
  },
  "bugs": {
    "url": "https://github.com/ZhgChgLi/JSRangeable/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^1"
  }
}
